      "@id": "#acceptance-test-sync",
      "@type": "HowTo",
      "name": "Synchronous ImageMagick acceptance test",
      "description": "Run the service directly with the sample image and store the returned ZIP archive containing the generated outputs.",
      "tool": [
        {
          "@id": "#tool-oscar-cli"
        }
