        }
      ]
    },
    {
      "@id": "#acceptance-test-async",
      "@type": "HowTo",
      "name": "Asynchronous ImageMagick acceptance test",
      "description": "Upload the sample input image, wait for OSCAR to process it, then download the generated artifacts and confirm that the grayscale PNG, edge PNG, and metrics JSON are present.",
      "tool": [
        {
          "@id": "#tool-oscar-cli"
        }
      ],
      "supply": [
        {
          "@id": "#supply-sample-image"
        }
      ],
      "step": [
        {
          "@id": "#step-async-put"
        },
        {
          "@id": "#step-async-wait"
        },
        {
          "@id": "#step-async-get"
        }
      ]
    },
    {
      "@id": "#tool-oscar-cli",
      "@type": "HowToTool",
      "name": "OSCAR CLI",
      "item": {
        "@id": "#oscar-cli"
      }
    },
    {
      "@id": "#supply-sample-image",
      "@type": "HowToSupply",
      "name": "Sample image",
      "item": {
        "@id": "input.png"
      }
    },
    {
      "@id": "#expected-output-zip",
      "@type": [
        "File",
        "MediaObject"
      ],
      "name": "Generated ZIP archive",
      "description": "ZIP file returned by synchronous invocation containing the grayscale image, edge image, and metrics JSON.",
      "encodingFormat": "application/zip"
    },
    {
      "@id": "#expected-output-artifacts",
      "@type": [
        "Dataset"
      ],
      "name": "Generated output artifacts",
      "description": "Output directory containing <stem>_gray.png, <stem>_edges.png, and <stem>_metrics.json for the uploaded image."
    },
    {
      "@id": "#step-sync-run",
      "@type": "HowToStep",
      "position": 1,
      "text": "Run the service synchronously with the sample image and store the returned ZIP file.",
      "potentialAction": {
        "@id": "#action-sync-run"
      }
    },
    {
      "@id": "#step-async-put",
      "@type": "HowToStep",
      "position": 1,
      "text": "Upload the sample input image to the service input path.",
      "potentialAction": {
        "@id": "#action-async-put"
      }
    },
    {
      "@id": "#step-async-wait",
      "@type": "HowToStep",
      "position": 2,
      "text": "Wait for the remote execution to generate the derived image files and metrics JSON.",
      "timeRequired": "PT20S"
    },
    {
      "@id": "#step-async-get",
      "@type": "HowToStep",
      "position": 3,
      "text": "Download the latest outputs and confirm that the expected files were generated.",
      "potentialAction": {
        "@id": "#action-async-get"
      }
    },
    {
      "@id": "#action-sync-run",
      "@type": "ConsumeAction",
      "name": "service run",
      "object": {
        "@id": "input.png"
      },
      "target": {
        "@id": "#entry-sync-run"
      },
      "result": {
        "@id": "#expected-output-zip"
      },
      "additionalProperty": [
        {
          "@id": "#command-template-sync-run"
        }
      ]
    },
    {
      "@id": "#entry-sync-run",
      "@type": "EntryPoint",
      "actionApplication": {
        "@id": "#oscar-cli"
      }
    },
    {
      "@id": "#command-template-sync-run",
      "@type": "PropertyValue",
      "propertyID": "commandTemplate",
      "value": "oscar-cli service run imagemagick --input {input} --output {destination}"
    },
    {
      "@id": "#action-async-put",
      "@type": "TransferAction",
      "name": "service put-file",
      "object": {
        "@id": "input.png"
      },
      "target": {
        "@id": "#entry-async-put"
      },
      "additionalProperty": [
        {
          "@id": "#command-template-async-put"
        }
      ]
    },
    {
      "@id": "#entry-async-put",
      "@type": "EntryPoint",
      "actionApplication": {
        "@id": "#oscar-cli"
      }
    },
    {
      "@id": "#command-template-async-put",
      "@type": "PropertyValue",
      "propertyID": "commandTemplate",
      "value": "oscar-cli service put-file imagemagick {source}"
    },
    {
      "@id": "#action-async-get",
      "@type": "TransferAction",
      "name": "service get-file",
      "target": {
        "@id": "#entry-async-get"
      },
      "result": {
        "@id": "#expected-output-artifacts"
      },
      "additionalProperty": [
        {
          "@id": "#command-template-async-get"
        }
      ]
    },
    {
      "@id": "#entry-async-get",
      "@type": "EntryPoint",
      "actionApplication": {
        "@id": "#oscar-cli"
      }
    },
    {
      "@id": "#command-template-async-get",
      "@type": "PropertyValue",
      "propertyID": "commandTemplate",
      "value": "oscar-cli service get-file imagemagick --download-latest-into {destination}"
    },
